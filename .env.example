# DecodedSix — Environment Variables
# Copy to .env.local and fill in values. Never commit .env.local.
# See docs/ENV_SETUP.md for where to get each value.

# Supabase (decodedsix-prod — isolated project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Map feature flag — false until November 19 2026 launch day
NEXT_PUBLIC_MAP_LIVE=false

# FastAPI backend (api/) — n8n + dashboard auth. Leave empty in dev for no auth.
DECODEDSIX_API_KEY=

# Same FastAPI backend, but the NEXT_PUBLIC_ variants the dashboard's client
# components read directly (src/app/dashboard/queue/page.tsx) — Next.js only
# inlines NEXT_PUBLIC_-prefixed vars into the browser bundle, so the
# server-only DECODEDSIX_API_KEY above is invisible to 'use client' code.
# Set both to the same FastAPI URL/key as above.
NEXT_PUBLIC_DECODEDSIX_API_URL=
NEXT_PUBLIC_DECODEDSIX_API_KEY=

# n8n webhook fired after an article is published — post-approval distribution
# workflow (n8n/post_approval_distribution.json). Leave empty to skip firing
# it; publish_article() no-ops silently when unset.
N8N_POST_APPROVAL_WEBHOOK_URL=

# Content agents
ANTHROPIC_API_KEY=
ORIGINALITY_API_KEY=
ELEVENLABS_API_KEY=
INVIDEO_API_KEY=

# YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# Systeme.io
SYSTEME_TAG_DS_MAP_WAITLIST=
SYSTEME_API_KEY=

# Affiliate tracking
AMAZON_ASSOCIATE_TAG=

# LinkedIn distribution (api/routes/distribute.py)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
